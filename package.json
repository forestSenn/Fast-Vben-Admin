{
  "name": "fast-vben-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/init.ps1",
    "backend:dev": "cd backend && fastapi dev app/main.py",
    "backend:lint": "cd backend && uv run ruff check app tests",
    "backend:test": "cd backend && uv run pytest",
    "frontend:dev": "pnpm --dir frontend dev",
    "frontend:build": "pnpm --dir frontend build",
    "frontend:typecheck": "pnpm --dir frontend -F @vben/web-antd run typecheck",
    "frontend:e2e": "pnpm --dir frontend -F @vben/web-antd run test:e2e",
    "generate:api": "node scripts/generate-openapi.mjs",
    "generate:manifest": "cd backend && uv run python -m app.modules.generate_manifest",
    "build:edition": "node scripts/build-edition.mjs",
    "migrate:edition": "cd backend && uv run python -m app.modules.migrate",
    "reconcile:modules": "cd backend && uv run python -m app.modules.reconcile",
    "outbox:dispatch": "cd backend && uv run python -m app.modules.outbox_worker --once",
    "dev": "docker compose up --build",
    "local:up": "powershell -ExecutionPolicy Bypass -File scripts/local-services.ps1 up",
    "local:down": "powershell -ExecutionPolicy Bypass -File scripts/local-services.ps1 down",
    "local:status": "powershell -ExecutionPolicy Bypass -File scripts/local-services.ps1 status",
    "local:logs": "powershell -ExecutionPolicy Bypass -File scripts/local-services.ps1 logs",
    "build": "pnpm frontend:build",
    "test": "pnpm backend:test",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down"
  }
}
